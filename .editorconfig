root = true

# ============================================================
# 全局默认
# ============================================================
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true

# ============================================================
# C/C++ 源代码
# ============================================================
[*.{cpp,h,hpp,cu,cuh,c}]
indent_style = space
indent_size = 4

# ============================================================
# Markdown：关闭行尾空格修剪（两个 trailing space 表示硬换行）
# ============================================================
[*.md]
trim_trailing_whitespace = false

# ============================================================
# JSON / YAML：可安全修剪行尾空格
# ============================================================
[*.{json,yaml,yml}]
indent_style = space
indent_size = 2
trim_trailing_whitespace = true

# ============================================================
# Windows 批处理
# ============================================================
[*.bat]
end_of_line = crlf

[*.cmd]
end_of_line = crlf
