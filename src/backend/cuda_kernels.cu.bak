#ifdef TR_USE_CUDA

#include <cuda_runtime.h>
#include <cuda_fp16.h>
#include "renaissance/core/philox.h"  // Philox算法（CPU/GPU通用）

// ============================================================================
// Basic Operation Kernels
// ============================================================================

__global__ void tr_axpy_fp32_kernel(const float* __restrict__ a,
                                    const float* __restrict__ b,
                                    float alpha,
                                    float* __restrict__ c,
                                    int64_t n) {
    int64_t idx = static_cast<int64_t>(blockIdx.x) * blockDim.x + threadIdx.x;
    int64_t stride = static_cast<int64_t>(blockDim.x) * gridDim.x;

    // Grid-stride loop: 每个线程处理多个元素，确保任意大小tensor都能正确处理
    for (; idx < n; idx += stride) {
        c[idx] = alpha * a[idx] + b[idx];
    }
}

__global__ void tr_fill_fp32_kernel(float* __restrict__ dst, float value, int64_t n) {
    int64_t idx = static_cast<int64_t>(blockIdx.x) * blockDim.x + threadIdx.x;
    int64_t stride = static_cast<int64_t>(blockDim.x) * gridDim.x;

    // Grid-stride loop: 每个线程处理多个元素，确保任意大小tensor都能正确处理
    for (; idx < n; idx += stride) {
        dst[idx] = value;
    }
}

__global__ void tr_relu_fwd_fp32_kernel(const float* __restrict__ x, float* __restrict__ y, int64_t n) {
    int64_t idx = static_cast<int64_t>(blockIdx.x) * blockDim.x + threadIdx.x;
    int64_t stride = static_cast<int64_t>(blockDim.x) * gridDim.x;

    // Grid-stride loop: 每个线程处理多个元素，确保任意大小tensor都能正确处理
    for (; idx < n; idx += stride) {
        y[idx] = fmaxf(0.0f, x[idx]);
    }
}

__global__ void tr_relu_fwd_fp32_mask_kernel(const float* __restrict__ x, float* __restrict__ y, int8_t* __restrict__ mask, int64_t n) {
    int64_t idx = static_cast<int64_t>(blockIdx.x) * blockDim.x + threadIdx.x;
    int64_t stride = static_cast<int64_t>(blockDim.x) * gridDim.x;

    // Grid-stride loop: 同时写入ReLU输出和INT8 bitmask（用于反向传播）
    for (; idx < n; idx += stride) {
        float v = x[idx];
        y[idx] = fmaxf(0.0f, v);
        mask[idx] = (v > 0.0f) ? static_cast<int8_t>(1) : static_cast<int8_t>(0);
    }
}

__global__ void tr_cast_fp16_to_fp32_kernel(const half* __restrict__ src, float* __restrict__ dst, int64_t n) {
    int64_t idx = static_cast<int64_t>(blockIdx.x) * blockDim.x + threadIdx.x;
    int64_t stride = static_cast<int64_t>(blockDim.x) * gridDim.x;

    // Grid-stride loop: 每个线程处理多个元素，确保任意大小tensor都能正确处理
    for (; idx < n; idx += stride) {
        dst[idx] = __half2float(src[idx]);
    }
}

__global__ void tr_cast_fp32_to_fp16_kernel(const float* __restrict__ src, half* __restrict__ dst, int64_t n) {
    int64_t idx = static_cast<int64_t>(blockIdx.x) * blockDim.x + threadIdx.x;
    int64_t stride = static_cast<int64_t>(blockDim.x) * gridDim.x;

    // Grid-stride loop: 每个线程处理多个元素，确保任意大小tensor都能正确处理
    for (; idx < n; idx += stride) {
        dst[idx] = __float2half(src[idx]);
    }
}

// ============================================================================
// Optimizer Update Kernels
// ============================================================================

__global__ void tr_lars_update_fp32_kernel(float* __restrict__ weight, const float* __restrict__ grad,
                                            float* __restrict__ momentum_buf,
                                            float lr, float trust_ratio,
                                            float weight_decay, float momentum,
                                            bool nesterov, int64_t n) {
    int64_t idx = static_cast<int64_t>(blockIdx.x) * blockDim.x + threadIdx.x;
    int64_t stride = static_cast<int64_t>(blockDim.x) * gridDim.x;

    // Grid-stride loop: 每个线程处理多个元素，确保任意大小tensor都能正确处理
    for (; idx < n; idx += stride) {
        float g = grad[idx] + weight_decay * weight[idx];
        float update = lr * trust_ratio * g;

        if (momentum_buf) {
            float m = momentum_buf[idx];
            float new_m = momentum * m + update;
            momentum_buf[idx] = new_m;

            if (nesterov) {
                update = momentum * new_m + update;
            } else {
                update = new_m;
            }
        }

        weight[idx] -= update;
    }
}

__global__ void tr_sgd_update_fp32_kernel(float* __restrict__ weight, const float* __restrict__ grad,
                                          float lr, float weight_decay, int64_t n) {
    int64_t idx = static_cast<int64_t>(blockIdx.x) * blockDim.x + threadIdx.x;
    int64_t stride = static_cast<int64_t>(blockDim.x) * gridDim.x;

    // Grid-stride loop: 每个线程处理多个元素，确保任意大小tensor都能正确处理
    for (; idx < n; idx += stride) {
        weight[idx] -= lr * (grad[idx] + weight_decay * weight[idx]);
    }
}

__global__ void tr_ema_update_fp32_kernel(const float* __restrict__ src, float* __restrict__ dst,
                                          float decay, int64_t n) {
    int64_t idx = static_cast<int64_t>(blockIdx.x) * blockDim.x + threadIdx.x;
    int64_t stride = static_cast<int64_t>(blockDim.x) * gridDim.x;

    // Grid-stride loop: 每个线程处理多个元素，确保任意大小tensor都能正确处理
    for (; idx < n; idx += stride) {
        dst[idx] = decay * dst[idx] + (1.0f - decay) * src[idx];
    }
}

// ============================================================================
// Random Number Generation Kernels (Philox-based)
// ============================================================================

/**
 * @brief Philox正态分布kernel（GPU直接生成）
 * @param n 元素数量
 * @param seed 全局种子
 * @param base_offset 基础偏移量（由Generator的原子操作预留）
 * @param mean 均值
 * @param std 标准差
 * @param out 输出数组（GPU内存）
 *
 * @note 使用philox.h中的设备端函数detail::philox_normal_pair
 * @note Box-Muller变换：每次生成2个正态分布随机数
 */
__global__ void tr_philox_normal_float_kernel(
    int n, uint64_t seed, uint64_t base_offset, float mean, float std, float* out
) {
    int idx = blockIdx.x * blockDim.x + threadIdx.x;
    if (idx >= n) return;

    // 每个线程处理一个输出位置
    // 偶数索引使用n0，奇数索引使用n1
    float n0, n1;
    tr::detail::philox_normal_pair(seed, base_offset + idx / 2, &n0, &n1);

    if (idx % 2 == 0) {
        out[idx] = mean + std * n0;
    } else {
        out[idx] = mean + std * n1;
    }
}

// ============================================================================
// CUDA Kernel Launch Wrappers (C linkage for calling from .cpp files)
// ============================================================================

extern "C" cudaError_t launch_tr_axpy_fp32_kernel(
    const float* __restrict__ a, const float* __restrict__ b, float alpha,
    float* __restrict__ c, int64_t n, cudaStream_t stream) {

    const int block_size = 256;
    const int grid_size = static_cast<int>((n + block_size - 1) / block_size);

    tr_axpy_fp32_kernel<<<grid_size, block_size, 0, stream>>>(a, b, alpha, c, n);
    return cudaGetLastError();
}

extern "C" cudaError_t launch_tr_fill_fp32_kernel(
    float* __restrict__ dst, float value, int64_t n, cudaStream_t stream) {

    const int block_size = 256;
    const int grid_size = static_cast<int>((n + block_size - 1) / block_size);

    tr_fill_fp32_kernel<<<grid_size, block_size, 0, stream>>>(dst, value, n);
    return cudaGetLastError();
}

extern "C" cudaError_t launch_tr_relu_fwd_fp32_kernel(
    const float* __restrict__ x, float* __restrict__ y, int64_t n, cudaStream_t stream) {

    const int block_size = 256;
    const int grid_size = static_cast<int>((n + block_size - 1) / block_size);

    tr_relu_fwd_fp32_kernel<<<grid_size, block_size, 0, stream>>>(x, y, n);
    return cudaGetLastError();
}

extern "C" cudaError_t launch_tr_relu_fwd_fp32_mask_kernel(
    const float* __restrict__ x, float* __restrict__ y, int8_t* __restrict__ mask, int64_t n, cudaStream_t stream) {

    const int block_size = 256;
    const int grid_size = static_cast<int>((n + block_size - 1) / block_size);

    tr_relu_fwd_fp32_mask_kernel<<<grid_size, block_size, 0, stream>>>(x, y, mask, n);
    return cudaGetLastError();
}

// ============================================================================
// ReLU Backward Kernel（使用 bitmask 门控）
// dX = dY * mask，其中 mask 由前向传播生成（1 表示 x>0）
// ============================================================================

__global__ void tr_relu_bwd_fp32_kernel(const float* __restrict__ dY,
                                        const int8_t* __restrict__ mask,
                                        float* __restrict__ dX, int64_t n) {
    int64_t idx = static_cast<int64_t>(blockIdx.x) * blockDim.x + threadIdx.x;
    int64_t stride = static_cast<int64_t>(blockDim.x) * gridDim.x;

    for (; idx < n; idx += stride) {
        dX[idx] = mask[idx] ? dY[idx] : 0.0f;
    }
}

extern "C" cudaError_t launch_tr_relu_bwd_fp32_kernel(
    const float* __restrict__ dY, const int8_t* __restrict__ mask,
    float* __restrict__ dX, int64_t n, cudaStream_t stream) {

    const int block_size = 256;
    const int grid_size = static_cast<int>((n + block_size - 1) / block_size);

    tr_relu_bwd_fp32_kernel<<<grid_size, block_size, 0, stream>>>(dY, mask, dX, n);
    return cudaGetLastError();
}

extern "C" cudaError_t launch_tr_cast_fp16_to_fp32_kernel(
    const half* __restrict__ src, float* __restrict__ dst, int64_t n, cudaStream_t stream) {

    const int block_size = 256;
    const int grid_size = static_cast<int>((n + block_size - 1) / block_size);

    tr_cast_fp16_to_fp32_kernel<<<grid_size, block_size, 0, stream>>>(src, dst, n);
    return cudaGetLastError();
}

extern "C" cudaError_t launch_tr_cast_fp32_to_fp16_kernel(
    const float* __restrict__ src, half* __restrict__ dst, int64_t n, cudaStream_t stream) {

    const int block_size = 256;
    const int grid_size = static_cast<int>((n + block_size - 1) / block_size);

    tr_cast_fp32_to_fp16_kernel<<<grid_size, block_size, 0, stream>>>(src, dst, n);
    return cudaGetLastError();
}

extern "C" cudaError_t launch_tr_lars_update_fp32_kernel(
    float* __restrict__ weight, const float* __restrict__ grad,
    float* __restrict__ momentum_buf, float lr, float trust_ratio,
    float weight_decay, float momentum, bool nesterov, int64_t n, cudaStream_t stream) {

    const int block_size = 256;
    const int grid_size = static_cast<int>((n + block_size - 1) / block_size);

    tr_lars_update_fp32_kernel<<<grid_size, block_size, 0, stream>>>(
        weight, grad, momentum_buf, lr, trust_ratio, weight_decay, momentum, nesterov, n
    );
    return cudaGetLastError();
