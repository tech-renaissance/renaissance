extern "C" cudaError_t launch_tr_philox_normal_float_kernel(
    int n, uint64_t seed, uint64_t base_offset,
    float mean, float std, float* out, cudaStream_t stream) {

    const int block_size = 256;
    const int grid_size = (n + block_size - 1) / block_size;

    tr_philox_normal_float_kernel<<<grid_size, block_size, 0, stream>>>(
        n, seed, base_offset, mean, std, out
    );

    return cudaGetLastError();
}

// ============================================================================
// Flatten Kernel (NHWC padded 4D → compact 2D, 含 BWD unflatten)
// ============================================================================

__global__ void tr_flatten_fwd_fp32_kernel(
    const float* __restrict__ in, float* __restrict__ out,
    int N, int H, int W, int C,
    size_t stride_n, size_t stride_h, size_t stride_w, size_t stride_c,
    size_t out_row_stride)
{
    int total = N * H * W * C;
    int idx = blockIdx.x * blockDim.x + threadIdx.x;
    int step = blockDim.x * gridDim.x;

    for (; idx < total; idx += step) {
        int n = idx / (H * W * C);
        int rem = idx % (H * W * C);
        int h = rem / (W * C);
        rem %= (W * C);
        int w = rem / C;
        int c = rem % C;

        size_t in_off  = n * stride_n + h * stride_h + w * stride_w + c * stride_c;
        int feature = h * W * C + w * C + c;
        out[n * out_row_stride + feature] = in[in_off];
    }
}

__global__ void tr_flatten_bwd_fp32_kernel(
    const float* __restrict__ in, float* __restrict__ out,
    int N, int H, int W, int C,
    size_t stride_n, size_t stride_h, size_t stride_w, size_t stride_c,
    size_t in_row_stride)
{
    int total = N * H * W * C;
    int idx = blockIdx.x * blockDim.x + threadIdx.x;
    int step = blockDim.x * gridDim.x;

    for (; idx < total; idx += step) {
        int n = idx / (H * W * C);
        int rem = idx % (H * W * C);
        int h = rem / (W * C);
        rem %= (W * C);
        int w = rem / C;
        int c = rem % C;

        int feature = h * W * C + w * C + c;
        size_t in_off  = n * in_row_stride + feature;
        size_t out_off = n * stride_n + h * stride_h + w * stride_w + c * stride_c;
        out[out_off] = in[in_off];
    }
}

extern "C" cudaError_t launch_tr_flatten_fwd_fp32_kernel(
    const float* __restrict__ in, float* __restrict__ out,
    int N, int H, int W, int C,
    size_t stride_n, size_t stride_h, size_t stride_w, size_t stride_c,
    size_t out_row_stride, cudaStream_t stream)
{
    int total = N * H * W * C;
    const int block_size = 256;
    const int grid_size = (total + block_size - 1) / block_size;

    tr_flatten_fwd_fp32_kernel<<<grid_size, block_size, 0, stream>>>(
        in, out, N, H, W, C, stride_n, stride_h, stride_w, stride_c, out_row_stride);
    return cudaGetLastError();
}

extern "C" cudaError_t launch_tr_flatten_bwd_fp32_kernel(
    const float* __restrict__ in, float* __restrict__ out,
    int N, int H, int W, int C,
    size_t stride_n, size_t stride_h, size_t stride_w, size_t stride_c,
    size_t in_row_stride, cudaStream_t stream)
{
    int total = N * H * W * C;
    const int block_size = 256;
    const int grid_size = (total + block_size - 1) / block_size;

    tr_flatten_bwd_fp32_kernel<<<grid_size, block_size, 0, stream>>>(
        in, out, N, H, W, C, stride_n, stride_h, stride_w, stride_c, in_row_stride);
    return cudaGetLastError();
}

// ============================================================================
// FC Forward Kernel (naive matmul + optional bias)
// ============================================================================
// Layout (consistent with fc_fwd_op.cpp cuDNN Frontend graph):
//   X: [batch, in_features]     row_stride = x_row_stride
//   W: [out_features, in_features] row_stride = w_row_stride
//   Y: [batch, out_features]    row_stride = y_row_stride
//   b: [out_features] (optional) compact contiguous
// ============================================================================

__global__ void tr_fc_fwd_fp32_kernel(
    const float* __restrict__ x,
    const float* __restrict__ w,
    const float* __restrict__ b,
    float* __restrict__ y,
    int batch, int in_features, int out_features,
    size_t x_row_stride, size_t w_row_stride, size_t y_row_stride)
{
    int idx = blockIdx.x * blockDim.x + threadIdx.x;
    int total = batch * out_features;
    int step  = blockDim.x * gridDim.x;

    for (; idx < total; idx += step) {
        int b_idx = idx / out_features;
        int o     = idx % out_features;

        const float* x_row = x + b_idx * x_row_stride;
        const float* w_row = w + o * w_row_stride;

        float sum = 0.0f;
        for (int i = 0; i < in_features; ++i) {
            sum += x_row[i] * w_row[i];
        }

        if (b != nullptr) {
            sum += b[o];
        }

        y[b_idx * y_row_stride + o] = sum;
    }
}

extern "C" cudaError_t launch_tr_fc_fwd_fp32_kernel(
    const float* __restrict__ x,
    const float* __restrict__ w,
    const float* __restrict__ b,
    float* __restrict__ y,
    int batch, int in_features, int out_features,
    size_t x_row_stride, size_t w_row_stride, size_t y_row_stride,
    cudaStream_t stream)
{
    int total = batch * out_features;
    const int block_size = 256;
    const int grid_size  = (total + block_size - 1) / block_size;

    tr_fc_fwd_fp32_kernel<<<grid_size, block_size, 0, stream>>>(
        x, w, b, y, batch, in_features, out_features,
        x_row_stride, w_row_stride, y_row_stride);
    return cudaGetLastError();
}

// ============================================================================
// FC Backward Kernel (naive matmul for dX = dY @ W)
// ============================================================================
// Layout:
//   dY: [batch, out_features]   row_stride = dy_row_stride
//   W:  [out_features, in_features] row_stride = w_row_stride
//   dX: [batch, in_features]    row_stride = dx_row_stride
// ============================================================================

__global__ void tr_fc_bwd_fp32_kernel(
    const float* __restrict__ dy,
    const float* __restrict__ w,
    float* __restrict__ dx,
    int batch, int in_features, int out_features,
    size_t dy_row_stride, size_t w_row_stride, size_t dx_row_stride)
{
    int idx = blockIdx.x * blockDim.x + threadIdx.x;
    int total = batch * in_features;
    int step  = blockDim.x * gridDim.x;

    for (; idx < total; idx += step) {
        int b_idx = idx / in_features;
        int i     = idx % in_features;

        const float* dy_row = dy + b_idx * dy_row_stride;

        float sum = 0.0f;
        for (int o = 0; o < out_features; ++o) {
            const float* w_row = w + o * w_row_stride;
            sum += dy_row[o] * w_row[i];
        }

        dx[b_idx * dx_row_stride + i] = sum;
    }
}

extern "C" cudaError_t launch_tr_fc_bwd_fp32_kernel(
    const float* __restrict__ dy,
    const float* __restrict__ w,
    float* __restrict__ dx,
    int batch, int in_features, int out_features,
    size_t dy_row_stride, size_t w_row_stride, size_t dx_row_stride,
    cudaStream_t stream)
{
    int total = batch * in_features;
    const int block_size = 256;
    const int grid_size  = (total + block_size - 1) / block_size;

    tr_fc_bwd_fp32_kernel<<<grid_size, block_size, 0, stream>>>(
        dy, w, dx, batch, in_features, out_features,
        dy_row_stride, w_row_stride, dx_row_stride);
    return cudaGetLastError();
}

#endif // TR_USE_CUDA
