#include "renaissance/task/simple_task.h"

namespace tr {

// ============================================================================
// SimpleTask 实现
// ============================================================================
//
// SimpleTask 是纯头文件驱动的类，所有功能通过 using 声明委托给 TaskBase：
//
// 1. alloc / alloc_scalar → TaskBase::alloc / TaskBase::alloc_scalar
//    在 PLANNING 阶段分配 DTensor，由 MemoryPlan 管理偏移量
//
// 2. finalize_memory → TaskBase::finalize_memory
//    锁定 MemoryPlan，从 PLANNING 进入 MEMORY_LOCKED
//
// 3. add_graph → TaskBase::add_graph
//    在 MEMORY_LOCKED 阶段注册命名 ComputationGraph
//
// 4. run → TaskBase::run
//    在 COMPILED 阶段执行已注册的 CUDA Graph 或 CPU 任务列表
//
// 5. compile → TaskBase::compile（公共接口，无需 using）
//    执行完整编译管线：on_prepare() → 硬件分配 → 图捕获
//
// on_prepare() 覆写为空实现，因为手动绘图场景下
// 用户已通过 alloc/add_graph 构建完整 IR，无需 Compiler 自动生成
//
// TaskBase::on_prepare() 是纯虚函数，SimpleTask 必须覆写
// （Task 的覆写版本会驱动 Compiler 生成完整 IR）
//
// 析构函数由 TaskBase 和 Backend RAII 管理，无需额外清理
//
// ============================================================================

// 所有方法均为头文件内联或 using 声明，无需源文件实现
// 此文件仅作为编译单元存在，确保项目目录结构一致性

} // namespace tr
