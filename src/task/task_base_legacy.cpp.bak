namespace tr {
    // AXPY
    cudaError_t launch_tr_axpy_fp32_kernel(
        const float* __restrict__ a, const float* __restrict__ b, float alpha,
        float* __restrict__ c, int N, int H, int W, int C,
        size_t stride_n, size_t stride_h, size_t stride_w, size_t stride_c,
        cudaStream_t stream);

    // CAST
    cudaError_t launch_tr_cast_fp16_to_fp32_kernel(
        const half* __restrict__ src, float* __restrict__ dst, int64_t n, cudaStream_t stream);

    cudaError_t launch_tr_cast_fp32_to_fp16_kernel(
        const float* __restrict__ src, half* __restrict__ dst, int64_t n, cudaStream_t stream);

    // ReLU
    cudaError_t launch_tr_relu_fwd_fp32_kernel(
        const float* __restrict__ x, float* __restrict__ y, int64_t n,
        int64_t n_stride, int64_t h_stride, int64_t w_stride, int64_t c_stride, cudaStream_t stream);

    cudaError_t launch_tr_relu_fwd_fp32_mask_kernel(
        const float* __restrict__ x, float* __restrict__ y, int8_t* __restrict__ mask, int64_t n,
        int64_t n_stride, int64_t h_stride, int64_t w_stride, int64_t c_stride, cudaStream_t stream);

    cudaError_t launch_tr_relu_bwd_fp32_kernel(
        const float* __restrict__ dY, const int8_t* __restrict__ mask,
        float* __restrict__ dX, int64_t n,
        int64_t n_stride, int64_t h_stride, int64_t w_stride, int64_t c_stride, cudaStream_t stream);

    // Flatten
    cudaError_t launch_tr_flatten_fwd_fp32_kernel(
        const float* __restrict__ in, float* __restrict__ out,
        int N, int H, int W, int C,
        size_t stride_n, size_t stride_h, size_t stride_w, size_t stride_c,
        size_t out_row_stride, cudaStream_t stream);

    cudaError_t launch_tr_flatten_bwd_fp32_kernel(
        const float* __restrict__ in, float* __restrict__ out,
        int N, int H, int W, int C,
        size_t stride_n, size_t stride_h, size_t stride_w, size_t stride_c,
        size_t in_row_stride, cudaStream_t stream);

    // FC
    cudaError_t launch_tr_fc_fwd_fp32_kernel(
        const float* __restrict__ x, const float* __restrict__ w,
        const float* __restrict__ b, float* __restrict__ y,
        int batch, int in_features, int out_features,
        size_t x_row_stride, size_t w_row_stride, size_t y_row_stride,
        cudaStream_t stream);

    cudaError_t launch_tr_fc_bwd_fp32_kernel(
        const float* __restrict__ dy, const float* __restrict__ w,
        float* __restrict__ dx,
        int batch, int in_features, int out_features,
        size_t dy_row_stride, size_t w_row_stride, size_t dx_row_stride,
        cudaStream_t stream);

    // Optimizer updates
    cudaError_t launch_tr_lars_update_fp32_kernel(
        float* __restrict__ weight, const float* __restrict__ grad,
        float* __restrict__ momentum_buf, float lr, float trust_ratio,
        float weight_decay, float momentum, bool nesterov, int64_t n, cudaStream_t stream);

    cudaError_t launch_tr_sgd_update_fp32_kernel(
