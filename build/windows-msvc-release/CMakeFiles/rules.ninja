#############################################
# Rule for re-running cmake.

rule RERUN_CMAKE
  command = T:\Softwares\CMake\bin\cmake.exe --regenerate-during-build -SR:\renaissance -BR:\renaissance\build\windows-msvc-release
  description = Re-running CMake...
  generator = 1


#############################################
# Rule for cleaning all built files.

rule CLEAN
  command = C:\Python314\Scripts\ninja.exe $FILE_ARG -t clean $TARGETS
  description = Cleaning all built files...


#############################################
# Rule for printing all primary targets available.

rule HELP
  command = C:\Python314\Scripts\ninja.exe -t targets
  description = All primary targets available:

